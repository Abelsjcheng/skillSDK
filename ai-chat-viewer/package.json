{
  "name": "ai-chat-viewer",
  "version": "1.0.0",
  "description": "AI 问答展示前端项目 - 支持网页运行和页面打包导出",
  "main": "dist/lib/index.js",
  "module": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "files": [
    "dist/lib",
    "dist/create-assistant-page"
  ],
  "scripts": {
    "dev": "webpack serve --mode development --open",
    "build": "webpack --mode production --env isProEnv=true",
    "build:uat": "webpack --mode production --env isProEnv=false",
    "build:lib": "webpack --config webpack.lib.config.js --mode production && tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:all": "npm run build && npm run build:lib",
    "build:require-demo": "npm run build:lib && webpack --config example/require-demo/webpack.config.js --mode production",
    "build:create-assistant-page": "webpack --config webpack.create-assistant-page.config.js --mode production",
    "build:digital-twin-demo": "webpack --config example/digital-twin-demo/webpack.config.js --mode production",
    "build:assistant-components-demo": "npm run build:lib && webpack --config example/assistant-components-demo/webpack.config.js --mode production",
    "serve:require-demo": "webpack serve --config example/require-demo/webpack.config.js --mode development --open",
    "serve:create-assistant-page": "webpack serve --config webpack.create-assistant-page.config.js --mode development --open",
    "serve:digital-twin-demo": "webpack serve --config example/digital-twin-demo/webpack.config.js --mode development --open",
    "serve:assistant-components-demo": "npm run build:lib && webpack serve --config example/assistant-components-demo/webpack.config.js --mode development --open",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest --runInBand"
  },
  "keywords": [
    "react",
    "ai",
    "chat",
    "viewer",
    "component"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "core-js": "3.44.0",
    "http-serve": "^1.0.1",
    "react": "18.3.1",
    "react-router": "6.30.3",
    "react-syntax-highlighter": "15.6.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-proposal-optional-chaining": "7.21.0",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.6",
    "@types/react-syntax-highlighter": "15.5.10",
    "@typescript-eslint/eslint-plugin": "7.2.0",
    "@typescript-eslint/parser": "7.2.0",
    "babel-jest": "30.3.0",
    "babel-loader": "9.2.1",
    "copy-webpack-plugin": "12.0.2",
    "css-loader": "6.11.0",
    "eslint": "8.57.0",
    "html-webpack-plugin": "5.6.5",
    "identity-obj-proxy": "3.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "katex": "0.16.21",
    "less": "4.5.1",
    "less-loader": "12.2.0",
    "react-dom": "18.3.1",
    "react-markdown": "8.0.7",
    "rehype-katex": "6.0.3",
    "rehype-raw": "6.1.1",
    "remark-breaks": "3.0.3",
    "remark-gfm": "3.0.1",
    "remark-math": "5.1.1",
    "style-loader": "3.3.4",
    "typescript": "5.9.3",
    "webpack": "5.105.4",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "5.2.3"
  }
}
